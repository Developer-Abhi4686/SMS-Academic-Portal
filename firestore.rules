rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || (isSignedIn() && resource.data.role == 'student');
      allow write: if isOwner(userId);
    }

    match /students_8A/{id} { allow read: if isSignedIn(); }
    match /students_8B/{id} { allow read: if isSignedIn(); }
    match /students_8C/{id} { allow read: if isSignedIn(); }
    match /students_8D/{id} { allow read: if isSignedIn(); }
    match /students_8E/{id} { allow read: if isSignedIn(); }
    match /students_9A/{id} { allow read: if isSignedIn(); }
    match /students_9B/{id} { allow read: if isSignedIn(); }
    match /students_9C/{id} { allow read: if isSignedIn(); }
    match /students_9D/{id} { allow read: if isSignedIn(); }
    match /students_9E/{id} { allow read: if isSignedIn(); }
    match /students_10A/{id} { allow read: if isSignedIn(); }
    match /students_10B/{id} { allow read: if isSignedIn(); }
    match /students_10C/{id} { allow read: if isSignedIn(); }
    match /students_10D/{id} { allow read: if isSignedIn(); }
    match /students_10E/{id} { allow read: if isSignedIn(); }

    match /attendance/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /memories/{id} {
      allow read, write: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}
